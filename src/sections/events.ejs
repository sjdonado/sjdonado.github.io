<section class="flex flex-col flex-wrap my-4" id="events">
  <a class="text-xl my-4" href="#events">
    <%= events.title %>
  </a>
  <div class="flex flex-wrap justify-center">
    <% events.items.forEach(function(item, index) { %>
      <div class="flex flex-col items-start w-72 m-1 rounded-lg border h-full self-start">
        <div class="relative">
          <img
            class="object-cover object-right-top w-72 h-48 rounded-t-lg bg-gray-100"
            src="<%= item.image %>"
            alt="<%= item.description %>"
            width="286"
            height="192"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col w-full">
          <span class="text-sm text-center border-b py-1">
            <%= item.title %>
          </span>
          <span class="text-xs px-2 py-1">
            <%= item.description %>
          </span>
        </div>
      </div>
    <% }); %>
  </div>
</section>
