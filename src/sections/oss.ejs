<section class="flex flex-col flex-wrap my-4" id="oss">
  <a class="text-xl my-4" href="#oss">
    <%= oss.title %>
  </a>
  <div class="flex flex-wrap justify-center">
    <% oss.items.forEach(function(item, index) { %>
      <div class="flex flex-col border rounded-lg w-72 m-2">
        <a
          target="_blank"
          rel="noreferrer"
          href="<%= item.link %>"
        >
          <div class="relative">
            <img
              class="object-cover object-center rounded-t-lg w-full h-32"
              src="<%= item.image %>"
              alt="<%= item.description %>"
              loading="lazy"
            />
          </div>
          <div class="w-full p-2">
            <p class="font-semibold m-b-4"><%= item.title %></p>
            <p class="text-xs text-gray-500 min-h-[3rem] m-b-2">
              <%= item.description %>
            </p>
            <span class="text-xs text-gray-500 underline">
              <%= item.link %>
            </span>
          </div>
        </a>
      </div>
    <% }); %>
  </div>
</section>
