<section class="flex flex-col flex-wrap my-4" id="devto">
  <a class="text-xl my-4" href="#devto">
    <%= devto.title %>
  </a>
  <ul class="divide-y space-y-2">
    <% devto.items.forEach(function(item, index) { %>
      <li class="flex items-center justify-start space-x-2 p-2">
        <span><%= devto.items.length - index %>.</span>
        <a 
          class="underline"
          target="_blank"
          rel="noreferrer"
          href="<%= item.link %>"
        >
          <%= item.title %>
        </a>
      </li>
    <% }); %>
  </ul>
</section>
