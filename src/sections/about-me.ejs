<section class="flex flex-col my-4" id="about-me">
  <a class="text-2xl my-4" href="#about-me"><%= me.title %></a>
  <div class="divide-y space-y-2">
    <% me.items.forEach(function(item) { %>
    <div class="p-2">
      <span><%= item.description %></span>
    </div>
    <% }); %>
  </div>
</section>
