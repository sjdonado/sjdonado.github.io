<section class="flex flex-col flex-wrap my-4" id="spotify">
  <a class="text-2xl my-4" href="spotify"><%= spotify.title %></a>
  <% spotify.items.forEach(function(item, index) { %>
    <iframe
      class="border-0"
      height="180"
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
      src="<%= item.link %>"
    ></iframe>
  <% }); %>
</section>
